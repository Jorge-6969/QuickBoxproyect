<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="485.0" prefWidth="718.0" xmlns="http://javafx.com/javafx/18" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cargarPanel.vistas.VentaController">

   <children>
      <TableView fx:id="tablaCarrito" layoutX="88.0" layoutY="29.0" prefHeight="200.0" prefWidth="394.0">
         <columns>
            <TableColumn fx:id="colCodigo" prefWidth="83.0" text="ID" />
            <TableColumn fx:id="colNombre" prefWidth="87.0" text="Nombre" />
            <TableColumn fx:id="colPrecio" prefWidth="75.0" text="Precio" />
            <TableColumn fx:id="colCantidad" prefWidth="75.0" text="Cantidad" />
            <TableColumn fx:id="colSubtotal" prefWidth="75.0" text="Subtotal" />
         </columns>
      </TableView>

      <TextField fx:id="tfCodigo" layoutX="104.0" layoutY="250.0" prefHeight="31.0" prefWidth="100.0" promptText="Codigo" />
      <TextField fx:id="tfNombre" layoutX="215.0" layoutY="250.0" prefHeight="31.0" prefWidth="100.0" promptText="Nombre" />
      <TextField fx:id="tfPrecio" layoutX="328.0" layoutY="250.0" prefHeight="31.0" prefWidth="100.0" promptText="Precio" />
      <TextField fx:id="tfCantidad" layoutX="437.0" layoutY="250.0" prefHeight="25.0" prefWidth="82.0" promptText="Cantidad" />

      <Button fx:id="btnBuscar" layoutX="89.0" layoutY="309.0" mnemonicParsing="false" onAction="#buscarProducto" text="Buscar" />
      <Button fx:id="btnAgregar" layoutX="172.0" layoutY="309.0" mnemonicParsing="false" onAction="#agregarAlCarrito" text="Agregar" />
      <Button fx:id="btnQuitar" layoutX="268.0" layoutY="309.0" mnemonicParsing="false" onAction="#quitarSeleccion" text="Quitar" />
      <Button fx:id="btnVender" layoutX="356.0" layoutY="309.0" mnemonicParsing="false" onAction="#vender" text="Vender" />
      <Label fx:id="usuarioSesion" layoutX="500.0" layoutY="69.0" prefHeight="26.0" prefWidth="175.0" />
      <DatePicker fx:id="fecha" layoutX="500.0" layoutY="35.0" />
   </children>
</AnchorPane>
